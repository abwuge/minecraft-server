# ========= 群组服公共环境变量 =========
# 复制本文件为 .env 并按需修改; .env 不入 git

# GHCR 镜像所属组织/用户名 (小写)
GHCR_OWNER=your-github-username
IMAGE_TAG=latest

# Velocity 与子服共用的 modern forwarding 密钥
# 生成: openssl rand -hex 24
VELOCITY_FORWARDING_SECRET=change-me-to-random-hex

# RCON (子服内部使用, 仅在 docker 内网暴露)
RCON_PASSWORD=change-me-rcon

# JVM 内存
SURVIVAL_XMS=2G
SURVIVAL_XMX=6G
CREATIVE_XMS=1G
CREATIVE_XMX=3G

# 对外端口 (仅 proxy 暴露)
PROXY_PORT=25565
# Geyser Bedrock 端口 (UDP)
BEDROCK_PORT=19132

# MOTD (Velocity 3.3+ uses MiniMessage, not legacy § codes)
MOTD_PROXY=<green>生电群组服</green> <gray>|</gray> <aqua>survival</aqua> <gray>+</gray> <light_purple>creative</light_purple>
