# ========= 群组服公共环境变量 =========
# 运行时若无 .env，执行 make up 会自动生成。
# 也可手动复制本文件: cp .env.example .env

# GHCR 镜像所属组织/用户名 (小写)
# 不填默认使用 abwuge
GHCR_OWNER=abwuge
IMAGE_TAG=latest

# Velocity 与子服共用的 modern forwarding 密钥
# 不填会由 make init 自动生成随机密钥 (openssl rand -hex 24)
VELOCITY_FORWARDING_SECRET=change-me-to-random-hex

# RCON (子服内部使用, 仅在 docker 内网暴露)
# 不填会由 make init 自动生成随机密码 (openssl rand -hex 16)
RCON_PASSWORD=change-me-rcon

# JVM 内存
MAIN_XMS=2G
MAIN_XMX=6G
MIRROR_XMS=1G
MIRROR_XMX=3G
CREATE_XMS=1G
CREATE_XMX=3G

# 对外端口 (仅 proxy 暴露)
PROXY_PORT=25565
# Geyser Bedrock 端口 (UDP)
BEDROCK_PORT=19132

# MOTD (Velocity 3.3+ uses MiniMessage, not legacy § codes)
MOTD_PROXY=<green>生电群组服</green> <gray>|</gray> <aqua>main</aqua> <gray>+</gray> <yellow>mirror</yellow> <gray>+</gray> <light_purple>create</light_purple>

# MCSManager 面板端口
MCSM_WEB_PORT=23333
MCSM_DAEMON_PORT=24444
